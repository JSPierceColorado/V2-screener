# Required
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex

GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_WORKSHEET_NAME=Screener
GOOGLE_SERVICE_ACCOUNT_JSON={...}

# Screener behavior
BATCH_SIZE=100
LOOKBACK_DAYS=430
SHEET_CLEAR_MAX_ROWS=20000

# Session gates
# Production default: false. Set true to populate during pre-market/after-hours windows.
ALLOW_EXTENDED_HOURS_DATA_PULL=true
MARKET_TIMEZONE=America/New_York
EXTENDED_HOURS_START=04:00
EXTENDED_HOURS_END=20:00

# Dev override: pulls even outside regular/extended sessions. Keep false in production.
ALLOW_OFF_HOURS_DATA_PULL=false

# Rate limits / robustness
REQUEST_TIMEOUT_SECONDS=10
REQUEST_RETRIES=5
REQUEST_SLEEP_SECONDS=1.25
RATE_LIMIT_SLEEP_SECONDS=30
ERROR_SLEEP_SECONDS=30
MARKET_CLOSED_SLEEP_SECONDS=60
SUCCESS_SLEEP_SECONDS=60
LOG_LEVEL=INFO
